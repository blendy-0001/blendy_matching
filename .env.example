# ========================================
# 協業マッチングシステム 環境変数設定
# ========================================
# このファイルを .env にコピーして値を入力してください
# cp .env.example .env

# Notion Integration Token
# https://www.notion.so/my-integrations から取得
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude API Key
# https://console.anthropic.com から取得
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# Notion データベース ID
# ========================================
# 以下の値は Notion DB の URL から取得してください
# https://notion.so/{database_id}?v={view_id}

# メンバーリスト DB
MEMBERS_DB_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# マッチング履歴 DB
MATCHING_HISTORY_DB_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# マッチング結果 DB
MATCHING_RESULTS_DB_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# マッチングされなかったメンバー DB
UNMATCHED_MEMBERS_DB_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ========================================
# FastAPI / セキュリティ設定
# ========================================

# CORS許可オリジン（カンマ区切り）
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# API認証キー（本番環境で使用）
API_KEY=your-secure-api-key-here

# ログレベル (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
